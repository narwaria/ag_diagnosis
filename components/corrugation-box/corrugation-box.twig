{{ attach_library('ag_diagnosis/threejs') }}

{% set title = title|default('Corrugated Box Preview') %}
{% set subtitle = subtitle|default('Customize box dimensions and preview the 3D corrugated box.') %}
{% set width = width|default(220) %}
{% set depth = depth|default(160) %}
{% set height = height|default(140) %}
{% set open = open|default(75) %}
{% set unit = unit|default('mm') %}
{% set material = material|default('5-ply-kraft') %}
{% set box_type = box_type|default('rsc') %}
{% set print_option = print_option|default('plain') %}
{% set quantity = quantity|default(500) %}
{% set request_quote_url = request_quote_url|default('/request-quote') %}
{% set canvas_height = canvas_height|default('520px') %}

<section class="ag-corrugation-box" data-component="corrugation-box">
  <div class="ag-corrugation-box__content">
    <div class="ag-corrugation-box__eyebrow">
      Ambey Global Packaging
    </div>

    <h2 class="ag-corrugation-box__title">
      {{ title }}
    </h2>

    <p class="ag-corrugation-box__subtitle">
      {{ subtitle }}
    </p>

    <div class="ag-corrugation-box__controls">
      <div class="ag-corrugation-box__presets" aria-label="Preset box sizes">
        <button type="button" data-box-preset="small">Small</button>
        <button type="button" data-box-preset="apparel">Apparel</button>
        <button type="button" data-box-preset="fmcg">FMCG</button>
        <button type="button" data-box-preset="heavy">Heavy</button>
      </div>

      <label>
        <span>Width</span>
        <input
          type="range"
          min="120"
          max="420"
          value="{{ width }}"
          data-box-width
        >
        <strong data-box-width-value>{{ width }} mm</strong>
      </label>

      <label>
        <span>Depth</span>
        <input
          type="range"
          min="100"
          max="320"
          value="{{ depth }}"
          data-box-depth
        >
        <strong data-box-depth-value>{{ depth }} mm</strong>
      </label>

      <label>
        <span>Height</span>
        <input
          type="range"
          min="80"
          max="300"
          value="{{ height }}"
          data-box-height
        >
        <strong data-box-height-value>{{ height }} mm</strong>
      </label>

      <label>
        <span>Open</span>
        <input
          type="range"
          min="0"
          max="100"
          value="{{ open }}"
          data-box-open
        >
        <strong data-box-open-value>{{ open }}%</strong>
      </label>

      <label>
        <span>Unit</span>
        <select data-box-unit>
          <option value="mm"{{ unit == 'mm' ? ' selected' }}>Millimeters</option>
          <option value="cm"{{ unit == 'cm' ? ' selected' }}>Centimeters</option>
          <option value="in"{{ unit == 'in' ? ' selected' }}>Inches</option>
        </select>
        <strong data-box-unit-value>{{ unit }}</strong>
      </label>

      <label>
        <span>Material</span>
        <select data-box-material>
          <option value="3-ply-kraft"{{ material == '3-ply-kraft' ? ' selected' }}>3-ply Kraft</option>
          <option value="5-ply-kraft"{{ material == '5-ply-kraft' ? ' selected' }}>5-ply Kraft</option>
          <option value="7-ply-heavy"{{ material == '7-ply-heavy' ? ' selected' }}>7-ply Heavy Duty</option>
          <option value="white-board"{{ material == 'white-board' ? ' selected' }}>White Board</option>
        </select>
        <strong data-box-material-value>5-ply</strong>
      </label>

      <label>
        <span>Type</span>
        <select data-box-type>
          <option value="rsc"{{ box_type == 'rsc' ? ' selected' }}>Regular Slotted Carton</option>
          <option value="mailer"{{ box_type == 'mailer' ? ' selected' }}>Mailer Box</option>
          <option value="die-cut"{{ box_type == 'die-cut' ? ' selected' }}>Die-cut Box</option>
          <option value="half-slotted"{{ box_type == 'half-slotted' ? ' selected' }}>Half-slotted Carton</option>
        </select>
        <strong data-box-type-value>RSC</strong>
      </label>

      <label>
        <span>Print</span>
        <select data-box-print>
          <option value="plain"{{ print_option == 'plain' ? ' selected' }}>Plain</option>
          <option value="one-color"{{ print_option == 'one-color' ? ' selected' }}>1-color Print</option>
          <option value="two-color"{{ print_option == 'two-color' ? ' selected' }}>2-color Print</option>
          <option value="full-color"{{ print_option == 'full-color' ? ' selected' }}>Full Color Print</option>
        </select>
        <strong data-box-print-value>Plain</strong>
      </label>

      <label>
        <span>Qty</span>
        <input
          type="number"
          min="100"
          step="50"
          value="{{ quantity }}"
          data-box-quantity
        >
        <strong data-box-quantity-value>{{ quantity }}</strong>
      </label>
    </div>

    <div class="ag-corrugation-box__info">
      <div>
        <strong>Strength</strong>
        <span data-box-strength>Calculating...</span>
      </div>
      <div>
        <strong>Volume</strong>
        <span data-box-volume>Calculating...</span>
      </div>
      <div>
        <strong>Payload</strong>
        <span data-box-payload>Calculating...</span>
      </div>
      <div>
        <strong>Estimated Cost</strong>
        <span data-box-cost>Calculating...</span>
      </div>
    </div>

    <a class="ag-corrugation-box__quote" href="{{ request_quote_url }}" data-box-quote-link>
      Box calculator
    </a>
  </div>

  <div class="ag-corrugation-box__viewer">
    <div
      class="ag-corrugation-box__canvas"
      style="height: {{ canvas_height }};"
      data-corrugation-viewer
      data-width="{{ width }}"
      data-depth="{{ depth }}"
      data-height="{{ height }}"
      data-open="{{ open }}"
      data-unit="{{ unit }}"
      data-material="{{ material }}"
      data-box-type="{{ box_type }}"
      data-print="{{ print_option }}"
      data-quantity="{{ quantity }}"
      data-quote-url="{{ request_quote_url }}"
    ></div>
  </div>
</section>
