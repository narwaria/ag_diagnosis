{% set card_orientation = orientation|default('vertical') %}
{% set card_style = style|default('framed') %}
{% set card_background = background|default('noColor') %}

{# Boolean instead of string #}
{% set is_text_centered = is_text_centered|default(false) %}
{% set is_clickable = url is not empty and url != 'No URL' %}


{# ===========================
   Card wrapper
=========================== #}

{% set card =
  html_cva(
    base: ['group relative flex h-full w-full rounded-xl shadow-2xl transition duration-300 md:rounded-2xl'],
    variants: {
      orientation: {
        vertical: 'flex-col',
        horizontal: 'md:flex-row'
      },
      isTextCentered: {
        true: 'text-center',
        false: 'text-left'
      },
      clickable: {
        true: 'cursor-pointer hover:scale-103 hover:shadow-sm',
        false: ''
      },
      style: {
        framed: 'gap-4 p-4 lg:gap-4 lg:p-6',
        full: ''
      },
      backgroundColor: {
        default: 'bg-card text-card-foreground hover:bg-card/90 hover:text-card-foreground/90',
        accent: 'bg-accent text-accent-foreground hover:bg-accent/80 hover:text-accent-foreground/80',
        primary: 'bg-primary text-primary-foreground hover:bg-primary/90 hover:text-primary-foreground/90',
        muted: 'bg-muted text-muted-foreground hover:bg-muted/90 hover:text-muted-foreground/90',
        bright: 'bg-bright text-bright-foreground hover:bg-bright/90 hover:text-bright-foreground/90',
        light: 'bg-light text-light-foreground hover:bg-light/90 hover:text-light-foreground/90',
        inverted: 'bg-foreground text-background hover:bg-foreground/90 hover:text-background/90',
        noColor: 'shadow-none hover:text-foreground/90'
      }
    }
  )
%}


{# ===========================
   Media wrapper
=========================== #}

{% set card_media =
  html_cva(
    base: 'aspect-video overflow-hidden',
    variants: {
      orientation: {
        vertical: '',
        horizontal: 'md:aspect-auto md:flex-[0_1_50%]'
      },
      style: {
        framed: 'rounded-lg',
        full: 'rounded-xl'
      }
    }
  )
%}


{# ===========================
   Content wrapper
=========================== #}

{% set card_content =
  html_cva(
    base: 'flex w-full flex-col items-baseline',
    variants: {
      orientation: {
        vertical: '',
        horizontal: 'md:flex-[0_1_50%]'
      },
      style: {
        framed: '',
        full: 'rounded-b p-4 lg:p-6'
      }
    }
  )
%}


<div
  class="{{ card.apply({
    orientation: card_orientation,
    isTextCentered: is_text_centered,
    clickable: is_clickable,
    style: card_style,
    backgroundColor: card_background
  }) }}"
>

  {# ===========================
     SAFE MEDIA CHECK
  =========================== #}

  {% if media is not null and media.src is defined and media.src is not empty %}

    <div
      class="{{ card_media.apply({
        orientation: card_orientation,
        style: card_style
      }) }}"
    >

      {% block media %}

        {{
          include(
            'canvas:image',
            {
              src: media.src,
              alt: media.alt|default(''),
              class: 'object-cover w-full h-full',
              width: media.width|default(null),
              height: media.height|default(null),
              sizes: card_orientation == 'vertical'
                ? 'auto, 100vw'
                : '50vw'
            },
            false,
            true
          )
        }}

      {% endblock %}

    </div>

  {% endif %}


  <div
    class="{{ card_content.apply({
      orientation: card_orientation,
      style: card_style
    }) }}"
  >

    <div class="@container flex w-full flex-col gap-1 md:gap-2">

      {# ===========================
         FIXED HEADING LOGIC
      =========================== #}

      <h3 class="text-xl font-semibold @sm:text-2xl @2xl:text-3xl">

        {% if is_clickable %}
          <a href="{{ url }}"
             class="after:absolute after:inset-0 after:content-['']">
            {{ heading_text }}
          </a>
        {% else %}
          {{ heading_text }}
        {% endif %}

      </h3>


      {% if start_date or start_time %}

        <p class="text-sm opacity-70">

          {{ start_date }}

          {% if start_time %}
            {{ start_date ? ' · ' }}
            {{ start_time }}
          {% endif %}

          {% if end_date or end_time %}

            {{ ' – ' }}

            {{ end_date }}

            {% if end_time %}
              {{ end_date ? ' · ' }}
              {{ end_time }}
            {% endif %}

          {% endif %}

        </p>

      {% endif %}


      {% if text %}

        <p class="mb-0 text-md @sm:text-lg @2xl:text-xl">
          {{ text }}
        </p>

      {% endif %}

    </div>

  </div>

</div>
